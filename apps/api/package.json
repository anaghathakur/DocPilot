{
  "name": "@docpilot/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "predev": "pnpm --filter @docpilot/parser build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "pretest": "pnpm --filter @docpilot/parser build",
    "test": "vitest run",
    "pretypecheck": "pnpm --filter @docpilot/parser build",
    "typecheck": "tsc --project tsconfig.json --noEmit && tsc --project tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@docpilot/parser": "workspace:*",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "@types/yauzl": "^3.4.0",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10"
  }
}
